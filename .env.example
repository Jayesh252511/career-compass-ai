# ──────────────────────────────────────────────────────────────
# Linnea — Career Compass AI  ·  Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# For Vercel: set these in Project Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────

# Supabase (public — safe to expose in the browser)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Supabase server-side (same as above for SSR)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# ──────────────────────────────────────────────────────────────
# The following secrets live in Supabase Edge Function secrets,
# NOT in Vercel. Set them via: supabase secrets set KEY=value
# ──────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ELEVENLABS_API_KEY=...
